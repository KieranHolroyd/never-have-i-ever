{
	"$schema": "https://railway.com/railway.schema.json",
	"build": {
		"builder": "RAILPACK",
		"watchPatterns": [
			"server/**",
			"packages/shared/**",
			"package.json",
			"bun.lock"
		]
	},
	"deploy": {
		"startCommand": "bun run --cwd server start",
		"healthcheckPath": "/",
		"healthcheckTimeout": 300,
		"restartPolicyType": "ON_FAILURE"
	}
}
