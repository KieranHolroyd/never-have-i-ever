{
	"$schema": "https://schema.railpack.com",
	"provider": "node",
	"packages": {
		"bun": "1.3"
	},
	"caches": {
		"bun-install": {
			"directory": "/root/.bun/install/cache",
			"type": "shared"
		}
	},
	"steps": {
		"install": {
			"inputs": [
				{
					"local": true,
					"include": ["package.json", "bun.lock", "server", "packages/shared"]
				}
			],
			"commands": [
				{
					"cmd": "mkdir -p client && printf '%s\\n' '{\"name\":\"app\",\"private\":true}' > client/package.json",
					"customName": "Stub client workspace package"
				},
				{
					"cmd": "bun install --frozen-lockfile",
					"customName": "Install monorepo dependencies"
				},
				{
					"cmd": "mkdir -p server/assets/games",
					"customName": "Create game data directory"
				}
			],
			"caches": ["bun-install"]
		}
	},
	"deploy": {
		"startCommand": "bun run --cwd server start",
		"aptPackages": ["ca-certificates"],
		"inputs": [
			{
				"step": "install",
				"include": ["."]
			}
		],
		"variables": {
			"NODE_ENV": "production"
		}
	}
}
