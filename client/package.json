{
	"name": "app",
	"version": "0.3.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:clean": "rm -rf .svelte-kit build .vercel *.tsbuildinfo && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check .",
		"format": "prettier --plugin-search-dir . --write .",
		"update:commit": "bun run scripts/update-version.ts",
		"test": "./node_modules/.bin/playwright test --",
		"test:smoke": "./node_modules/.bin/playwright test minimal-smoke.spec.ts --",
		"test:unit": "./node_modules/.bin/playwright test unit/ --",
		"test:integration": "./node_modules/.bin/playwright test integration/ --",
		"test:e2e": "./node_modules/.bin/playwright test e2e/ --",
		"test:ui": "./node_modules/.bin/playwright test --ui",
		"test:headed": "./node_modules/.bin/playwright test --headed",
		"test:debug": "./node_modules/.bin/playwright test --debug",
		"test:install": "./node_modules/.bin/playwright install",
		"test:install-deps": "./node_modules/.bin/playwright install-deps",
		"test:full": "node test-runner.js"
	},
	"devDependencies": {
		"@iconify-json/ic": "^1.2.4",
		"@iconify-json/mdi": "^1.2.3",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@types/uuid": "^11.0.0",
		"autoprefixer": "^10.5.0",
		"bun-types": "^1.3.13",
		"playwright": "^1.59.1",
		"postcss": "^8.5.10",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"sass": "^1.99.0",
		"svelte": "^5.55.4",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"tslib": "^2.8.1",
		"type-fest": "^5.6.0",
		"typescript": "^6.0.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.9"
	},
	"type": "module",
	"dependencies": {
		"@nhie/shared": "workspace:*",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"caniuse-lite": "^1.0.30001790",
		"figlet": "^1.11.0",
		"lucide-svelte": "^1.0.1",
		"posthog-js": "^1.370.1",
		"svelte-outside-click": "^1.1.2",
		"uuid": "^14.0.0"
	},
	"trustedDependencies": [
		"@parcel/watcher"
	]
}
